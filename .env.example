APP_NAME=Observabilidade
APP_VERSION=0.1.0
ENVIRONMENT=local
SERVICE_NAME=observabilidade-api
LOG_LEVEL=INFO

DOCS_ENABLED=true
METRICS_ENABLED=true

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
TRUSTED_HOSTS=localhost,127.0.0.1,testserver,api,observabilidade-api

OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_INSECURE=true

API_PORT=8000
GATEWAY_PORT=8088
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

TRAEFIK_IMAGE=traefik:v3.7.5
PROMETHEUS_IMAGE=prom/prometheus:v3.12.0
GRAFANA_IMAGE=grafana/grafana:13.0.2
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-in-production
GRAFANA_ROOT_URL=http://localhost:3000
